# Copy this file to .env for local development.
# On Render/Railway/etc, set these as dashboard environment variables instead — never commit a real .env.

PORT=3000

# Required for the "AI Draft" buttons (executive summary, description, remediation).
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Required to accept real payments. Get these from https://dashboard.stripe.com
# 1. Create a $9/month recurring Product -> copy its Price ID into STRIPE_PRICE_ID
# 2. Copy your Secret Key (starts with sk_live_ or sk_test_) into STRIPE_SECRET_KEY
# 3. Create a webhook endpoint pointing to https://yourdomain.com/api/stripe-webhook
#    listening for "checkout.session.completed", copy its signing secret below
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
